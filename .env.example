# Copiar a .env y completar valores reales.

# --- Postgres (misma DB que atc-noc-suite) ---
# DATABASE_URL=postgresql://om_read:pass@host:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=om_read
DB_PASSWORD=

# --- Correo (IMAP entra + SMTP sale; mismo buzón) ---
#
# Microsoft 365 (producción)
MAIL_IMAP_HOST=outlook.office365.com
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=smtp.office365.com
MAIL_SMTP_PORT=587
MAIL_USER=sebastian.apestey@americantower.com
MAIL_PASSWORD=
#
# --- Prueba con Gmail (comentar bloque M365 y usar esto) ---
# 1) Gmail → Configuración → Reenvío e IMAP → IMAP activado
# 2) Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseña de aplicación
# MAIL_IMAP_HOST=imap.gmail.com
# MAIL_IMAP_PORT=993
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_USER=tu.cuenta@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx
#
# --- Prueba con Proton (requiere Proton Mail Bridge en la misma máquina) ---
# MAIL_IMAP_HOST=127.0.0.1
# MAIL_IMAP_PORT=1143
# MAIL_SMTP_HOST=127.0.0.1
# MAIL_SMTP_PORT=1025
# MAIL_USER=noc_atc@proton.me
# MAIL_PASSWORD=<contraseña que muestra Bridge, no la de Proton>

# Firma del remitente (opcional)
# MAIL_FROM_NAME=NOC Bot
# MAIL_SIGNATURE_NAME=NOC Bot
# MAIL_SIGNATURE_COMPANY=American Tower Corporation
# MAIL_SIGNATURE_ADDRESS_LINE1=Avda. del Libertador 101 – Piso 19
# MAIL_SIGNATURE_ADDRESS_LINE2=Complejo Alrío – Torre Sur
# MAIL_SIGNATURE_ADDRESS_LINE3=Vicente López, Buenos Aires – Argentina
# MAIL_SIGNATURE_PHONE=NOC Office: +5411 21583591
# MAIL_SIGNATURE_EMAIL=noc_atc@americantower.com

# Dominios permitidos (coma-separados). Vacío = cualquier remitente.
MAIL_ALLOWED_SENDER_DOMAINS=

# --- Worker ---
POLL_INTERVAL_SECONDS=60
DRY_RUN=0
PROCESSED_DB_PATH=./data/processed.db
LOG_LEVEL=INFO
