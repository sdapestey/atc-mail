# Copiar a .env y completar valores reales.

# --- Postgres (misma DB que atc-noc-suite) ---
# DATABASE_URL=postgresql://om_read:pass@host:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=om_read
DB_PASSWORD=

# --- Buzón IMAP + SMTP (mismo usuario para leer y enviar) ---
MAIL_IMAP_HOST=imap.gmail.com
MAIL_IMAP_PORT=993
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_USER=atc.noc.ops@gmail.com
MAIL_PASSWORD=

# Microsoft 365 (alternativa):
# MAIL_IMAP_HOST=outlook.office365.com
# MAIL_SMTP_HOST=smtp.office365.com
# MAIL_USER=noc@americantower.com

# Remitentes From permitidos (default si vacío):
MAIL_ALLOWED_SENDER_DOMAINS=tmoviles.com.ar,retesar.com,americantower.com,digitsa.com.ar,rowing.com.ar,comfica.com

# Siempre en Cc de cada respuesta (aunque no vengan en el mail entrante):
MAIL_ALWAYS_CC=lucas.gimenez@americantower.com,facundo.vergara@americantower.com,noc_atc@americantower.com

# Firma (opcional)
# MAIL_FROM_NAME=NOC Bot
# MAIL_SIGNATURE_EMAIL=noc_atc@americantower.com

# --- Worker ---
POLL_INTERVAL_SECONDS=60
DRY_RUN=0
PROCESSED_DB_PATH=./data/processed.db
# Historial de consultas (CSV). Si vacío: mismo dir que PROCESSED_DB_PATH/timbrado_historico.csv
# TIMBRADO_HISTORICO_CSV_PATH=./data/timbrado_historico.csv
LOG_LEVEL=INFO
